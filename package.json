{
  "name": "stinfo",
  "version": "1.0.0",
  "description": "",
  "description": "Game performance analyzer",
  "author": {
    "name": "GameCheck Team",
    "email": "dev@gamecheck.app"
  },
  "homepage": "https://gamecheck.app",
  "main": "src/main/main.js",
  "build": {
    "appId": "com.gamecheck.app",
    "productName": "GameCheck",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "linux": {
      "target": ["AppImage"],
      "maintainer": "GameCheck Team <dev@gamecheck.app>"
    },
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["zip"]
    }
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:3000 && NODE_ENV=development electron . --ozone-platform-hint=auto",
    "build": "npm run build:renderer && electron-builder",
    "build:renderer": "vite build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.9",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "autoprefixer": "^10.5.0",
    "axios": "^1.15.1",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.8.0",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "systeminformation": "^5.31.5",
    "tailwindcss": "^4.2.4"
  }
}
